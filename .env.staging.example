# =============================================================================
# AMS Hub - Staging Environment Variables
# =============================================================================
# Copy this file to .env.staging and fill in the values before deploying.
# Never commit the actual .env.staging file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_ENV=prod

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=ams-apps-hub
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# -----------------------------------------------------------------------------
# Backend (Symfony)
# -----------------------------------------------------------------------------

# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_32_chars_minimum_random_string

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_key_strong_random_string

# Must match POSTGRES_* values above
DATABASE_URL=postgresql://ams_user:CHANGE_ME_strong_password_here@database:5432/ams-apps-hub?serverVersion=16&charset=utf8

# Public-facing URL (used by Symfony for link generation)
DEFAULT_URI=https://staging-ihub.wingleetdev.com

# Allowed CORS origins (regex)
CORS_ALLOW_ORIGIN=^https://staging-ihub\.wingleetdev\.com$

# SSO callback URL
SSO_CALLBACK_URL=https://staging-ihub.wingleetdev.com/auth/callback

# AMS API integration
AMS_API_URL=http://46.105.115.223:8181
AMS_API_DB=app_test
AMS_API_USER=CHANGE_ME_api_user
AMS_API_PASSWORD=CHANGE_ME_api_password

# -----------------------------------------------------------------------------
# Frontend (React/Vite)
# -----------------------------------------------------------------------------
VITE_API_URL=https://staging-ihub.wingleetdev.com

# -----------------------------------------------------------------------------
# SSO App
# -----------------------------------------------------------------------------
SSO_HUB_URL=http://ams-apps-hub-caddy
SSO_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32
