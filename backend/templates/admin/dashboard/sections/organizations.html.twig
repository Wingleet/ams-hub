<div class="table-responsive">
    <table class="table table-vcenter card-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Users</th>
                <th>Subscriptions</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            {% for organization in organizations %}
            <tr style="cursor: pointer;" onclick="window.location.href='{{ organizationUrls[organization.id] }}'" onmouseover="this.style.backgroundColor='#f5f5f5'" onmouseout="this.style.backgroundColor=''">
                <td>
                    <div class="d-flex align-items-center">
                        {% if organization.iconUrl %}
                            <img src="{{ organization.iconUrl }}" alt="{{ organization.name }}" class="avatar avatar-sm me-2">
                        {% endif %}
                        <span>{{ organization.name }}</span>
                    </div>
                </td>
                <td>
                    <span class="badge bg-blue">{{ organization.users|length }}</span>
                </td>
                <td>
                    <span class="badge bg-green">{{ organization.subscriptions|length }}</span>
                </td>
                <td>{{ organization.createdAt|date('d/m/Y') }}</td>
            </tr>
            {% endfor %}
            {% if organizations|length == 0 %}
            <tr>
                <td colspan="4" class="text-center text-muted">No organizations</td>
            </tr>
            {% endif %}
        </tbody>
    </table>
</div>
{% if totalItems > itemsPerPage %}
<div class="card-footer">
    <div class="d-flex align-items-center">
        <p class="text-muted mb-0">Showing {{ (currentPage - 1) * itemsPerPage + 1 }} to {{ (currentPage * itemsPerPage > totalItems) ? totalItems : currentPage * itemsPerPage }} of {{ totalItems }}</p>
        <div class="ms-auto">
            {% if currentPage > 1 %}
                <a href="#" data-section="organizations" data-page="{{ currentPage - 1 }}" class="btn btn-sm btn-outline-secondary pagination-link">Previous</a>
            {% endif %}
            <span class="mx-2">Page {{ currentPage }} of {{ totalPages }}</span>
            {% if currentPage < totalPages %}
                <a href="#" data-section="organizations" data-page="{{ currentPage + 1 }}" class="btn btn-sm btn-outline-secondary pagination-link">Next</a>
            {% endif %}
        </div>
    </div>
</div>
{% endif %}
