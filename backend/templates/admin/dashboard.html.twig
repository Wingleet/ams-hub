{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}
    <h1>🏠 Dashboard AMS APPS HUB</h1>
    <p>Welcome, {{ app.user.firstname }} {{ app.user.lastname }}</p>
{% endblock %}

{% block main %}
    <div class="alert alert-info">
        <strong>Welcome to the administration interface!</strong><br>
        Use the left menu to manage users, organizations and applications.
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">👥 Users</h5>
                    <p class="card-text">Manage user accounts and their access.</p>
                    <a href="{{ path('admin') }}?crudAction=index&crudControllerFqcn=App\\Controller\\Admin\\UserCrudController" class="btn btn-primary">View users</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">🏢 Organizations</h5>
                    <p class="card-text">Manage organizations and their configurations.</p>
                    <a href="{{ path('admin') }}?crudAction=index&crudControllerFqcn=App\\Controller\\Admin\\OrganizationCrudController" class="btn btn-primary">View organizations</a>
                </div>
            </div>
        </div>
        
        <div class="col-md-4">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">📱 Applications</h5>
                    <p class="card-text">Manage applications and their settings.</p>
                    <a href="{{ path('admin') }}?crudAction=index&crudControllerFqcn=App\\Controller\\Admin\\ApplicationCrudController" class="btn btn-primary">View applications</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
