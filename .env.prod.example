# =============================================================================
# AMS Hub - Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before deploying.
# Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
APP_ENV=prod
DOMAIN=example.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=ams-apps-hub
POSTGRES_USER=ams_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# -----------------------------------------------------------------------------
# Backend (Symfony)
# -----------------------------------------------------------------------------

# Generate with: php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=CHANGE_ME_32_chars_minimum_random_string

# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_jwt_secret_key_strong_random_string

# Must match POSTGRES_* values above
DATABASE_URL=postgresql://ams_user:CHANGE_ME_strong_password_here@database:5432/ams-apps-hub?serverVersion=16&charset=utf8

# Public-facing URL of the application (used by Symfony for link generation)
DEFAULT_URI=https://example.com

# Allowed CORS origins (regex)
CORS_ALLOW_ORIGIN=^https://example\.com$

# AMS API integration
AMS_API_URL=https://api.your-ams-server.com
AMS_API_DB=APP_NAME
AMS_API_USER=api_user
AMS_API_PASSWORD=CHANGE_ME_api_password

# -----------------------------------------------------------------------------
# Frontend (React/Vite)
# -----------------------------------------------------------------------------
VITE_API_URL=https://example.com

# -----------------------------------------------------------------------------
# Caddy (Reverse Proxy / TLS)
# -----------------------------------------------------------------------------
# Must match DOMAIN above; Caddy will automatically obtain a Let's Encrypt cert
# for this domain. Ensure ports 80 and 443 are open and the DNS points here.
DOMAIN=example.com
